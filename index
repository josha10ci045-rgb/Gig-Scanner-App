<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="apple-mobile-web-app-title" content="Gig Scanner" />
<title>TruPixel Gig Scanner</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
<style>
  :root {
    --bg: #0a0b0f;
    --surface: #12141a;
    --surface2: #1a1d26;
    --surface3: #22263a;
    --border: #252836;
    --accent: #c8f020;
    --teal: #20f0b4;
    --warn: #f0b820;
    --danger: #f02850;
    --text: #e2e4f0;
    --muted: #545870;
    --good: #20f0b4;
    --mid: #f0b820;
    --bad: #f02850;
    --safe-top: env(safe-area-inset-top, 44px);
    --safe-bottom: env(safe-area-inset-bottom, 20px);
  }

- { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

body {
background: var(–bg);
color: var(–text);
font-family: ‘DM Sans’, sans-serif;
height: 100dvh;
display: flex;
flex-direction: column;
overflow: hidden;
overscroll-behavior: none;
}

/* ── STATUS BAR SPACER ── */
.status-bar {
height: var(–safe-top);
background: var(–surface);
flex-shrink: 0;
}

/* ── HEADER ── */
header {
background: var(–surface);
padding: 12px 20px 14px;
border-bottom: 1px solid var(–border);
display: flex;
align-items: center;
gap: 10px;
flex-shrink: 0;
}
header h1 {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 1.55rem;
letter-spacing: 0.1em;
color: var(–accent);
line-height: 1;
}
header .sep { width: 1px; height: 16px; background: var(–border); }
header .subtitle {
font-family: ‘DM Mono’, monospace;
font-size: 0.58rem;
color: var(–muted);
letter-spacing: 0.12em;
text-transform: uppercase;
}
header .spacer { flex: 1; }
.status-pill {
font-family: ‘DM Mono’, monospace;
font-size: 0.58rem;
letter-spacing: 0.08em;
padding: 3px 9px;
border-radius: 20px;
border: 1px solid var(–border);
color: var(–muted);
transition: all 0.3s;
}
.status-pill.live { border-color: var(–good); color: var(–good); }
.status-pill.done { border-color: var(–accent); color: var(–accent); }

/* ── PAGES ── */
.pages {
flex: 1;
overflow: hidden;
position: relative;
}

.page {
position: absolute;
inset: 0;
display: flex;
flex-direction: column;
overflow: hidden;
opacity: 0;
pointer-events: none;
transform: translateX(20px);
transition: opacity 0.25s, transform 0.25s;
}
.page.active {
opacity: 1;
pointer-events: all;
transform: translateX(0);
}

/* ── BOTTOM NAV ── */
.bottom-nav {
background: var(–surface);
border-top: 1px solid var(–border);
display: grid;
grid-template-columns: repeat(3, 1fr);
padding-bottom: var(–safe-bottom);
flex-shrink: 0;
}
.nav-btn {
display: flex;
flex-direction: column;
align-items: center;
gap: 3px;
padding: 10px 8px 8px;
background: none;
border: none;
cursor: pointer;
color: var(–muted);
transition: color 0.2s;
position: relative;
}
.nav-btn.active { color: var(–accent); }
.nav-btn .nav-icon { font-size: 1.3rem; }
.nav-btn .nav-label {
font-family: ‘DM Mono’, monospace;
font-size: 0.58rem;
letter-spacing: 0.08em;
text-transform: uppercase;
}
.nav-badge {
position: absolute;
top: 6px;
right: calc(50% - 18px);
background: var(–accent);
color: #0a0b0f;
font-family: ‘DM Mono’, monospace;
font-size: 0.52rem;
font-weight: 700;
min-width: 16px;
height: 16px;
border-radius: 8px;
display: flex;
align-items: center;
justify-content: center;
padding: 0 3px;
}

/* ── PAGE: SCAN ── */
.scan-page-inner {
flex: 1;
overflow-y: auto;
-webkit-overflow-scrolling: touch;
padding: 20px 16px;
display: flex;
flex-direction: column;
gap: 16px;
}

.card {
background: var(–surface);
border: 1px solid var(–border);
border-radius: 14px;
padding: 16px;
}

.card-label {
font-family: ‘DM Mono’, monospace;
font-size: 0.6rem;
letter-spacing: 0.14em;
text-transform: uppercase;
color: var(–muted);
margin-bottom: 10px;
}

.url-input {
width: 100%;
background: var(–surface2);
border: 1px solid var(–border);
border-radius: 10px;
color: var(–text);
font-family: ‘DM Mono’, monospace;
font-size: 0.72rem;
padding: 12px 14px;
outline: none;
transition: border-color 0.2s;
-webkit-appearance: none;
}
.url-input::placeholder { color: var(–muted); }
.url-input:focus { border-color: var(–accent); }

.btn-scan {
width: 100%;
background: var(–accent);
color: #0a0b0f;
font-family: ‘Bebas Neue’, sans-serif;
font-size: 1.2rem;
letter-spacing: 0.12em;
border: none;
border-radius: 12px;
padding: 16px;
cursor: pointer;
transition: opacity 0.2s, transform 0.1s;
-webkit-appearance: none;
}
.btn-scan:active { transform: scale(0.97); opacity: 0.85; }
.btn-scan:disabled { opacity: 0.3; }

.btn-setup {
width: 100%;
background: transparent;
color: var(–teal);
font-family: ‘DM Mono’, monospace;
font-size: 0.72rem;
letter-spacing: 0.06em;
border: 1px solid rgba(32,240,180,0.3);
border-radius: 12px;
padding: 13px;
cursor: pointer;
-webkit-appearance: none;
}
.btn-setup:active { background: rgba(32,240,180,0.06); }

/* Stats row */
.stats-grid {
display: grid;
grid-template-columns: repeat(4, 1fr);
gap: 8px;
}
.stat-card {
background: var(–surface2);
border-radius: 10px;
padding: 10px 6px;
text-align: center;
border: 1px solid var(–border);
}
.stat-num {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 1.6rem;
line-height: 1;
color: var(–text);
}
.stat-num.green { color: var(–good); }
.stat-num.yellow { color: var(–mid); }
.stat-num.red { color: var(–bad); }
.stat-lbl {
font-family: ‘DM Mono’, monospace;
font-size: 0.52rem;
color: var(–muted);
text-transform: uppercase;
letter-spacing: 0.08em;
margin-top: 2px;
}

/* Progress */
.progress-wrap { display: flex; align-items: center; gap: 10px; }
.progress-bar {
flex: 1;
height: 4px;
background: var(–surface3);
border-radius: 2px;
overflow: hidden;
}
.progress-fill {
height: 100%;
background: var(–accent);
border-radius: 2px;
transition: width 0.4s ease;
width: 0%;
}
.progress-label {
font-family: ‘DM Mono’, monospace;
font-size: 0.6rem;
color: var(–muted);
flex-shrink: 0;
}

/* ── PAGE: LISTINGS ── */
.filter-scroll {
display: flex;
gap: 6px;
padding: 12px 16px;
overflow-x: auto;
-webkit-overflow-scrolling: touch;
border-bottom: 1px solid var(–border);
flex-shrink: 0;
}
.filter-scroll::-webkit-scrollbar { display: none; }
.chip {
font-family: ‘DM Mono’, monospace;
font-size: 0.62rem;
letter-spacing: 0.06em;
padding: 5px 12px;
border-radius: 20px;
border: 1px solid var(–border);
background: none;
color: var(–muted);
cursor: pointer;
white-space: nowrap;
flex-shrink: 0;
-webkit-appearance: none;
transition: all 0.15s;
}
.chip.active { border-color: var(–accent); color: var(–accent); background: rgba(200,240,32,0.08); }

.listing-scroll {
flex: 1;
overflow-y: auto;
-webkit-overflow-scrolling: touch;
}

.listing-row {
padding: 14px 16px;
border-bottom: 1px solid var(–border);
display: flex;
align-items: center;
gap: 12px;
cursor: pointer;
transition: background 0.15s;
active: background var(–surface2);
}
.listing-row:active { background: var(–surface2); }

.listing-row-info { flex: 1; min-width: 0; }
.listing-row-title {
font-size: 0.82rem;
font-weight: 500;
white-space: nowrap;
overflow: hidden;
text-overflow: ellipsis;
margin-bottom: 3px;
}
.listing-row-meta {
display: flex;
align-items: center;
gap: 6px;
}
.listing-row-city {
font-family: ‘DM Mono’, monospace;
font-size: 0.58rem;
color: var(–muted);
text-transform: uppercase;
letter-spacing: 0.08em;
}
.listing-row-snippet {
font-size: 0.7rem;
color: var(–muted);
white-space: nowrap;
overflow: hidden;
text-overflow: ellipsis;
flex: 1;
}

.score-badge {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 1.1rem;
width: 42px;
height: 42px;
border-radius: 10px;
display: flex;
align-items: center;
justify-content: center;
flex-shrink: 0;
line-height: 1;
}
.score-badge.good { background: rgba(32,240,180,0.12); color: var(–good); }
.score-badge.mid { background: rgba(240,184,32,0.12); color: var(–mid); }
.score-badge.bad { background: rgba(240,40,80,0.08); color: var(–bad); }
.score-badge.scam { background: rgba(240,40,80,0.15); color: var(–bad); font-size: 1rem; }
.score-badge.pending { background: var(–surface2); color: var(–muted); font-size: 0.7rem; }

.spinner {
display: inline-block;
width: 14px; height: 14px;
border: 2px solid var(–border);
border-top-color: var(–accent);
border-radius: 50%;
animation: spin 0.6s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

.chevron {
color: var(–muted);
font-size: 0.9rem;
flex-shrink: 0;
}

.empty-screen {
flex: 1;
display: flex;
flex-direction: column;
align-items: center;
justify-content: center;
color: var(–muted);
gap: 10px;
padding: 40px 24px;
text-align: center;
}
.empty-icon { font-size: 3rem; opacity: 0.25; }
.empty-text { font-size: 0.8rem; line-height: 1.65; max-width: 240px; }

/* ── DETAIL SHEET (slide up) ── */
.detail-sheet {
position: fixed;
inset: 0;
z-index: 50;
pointer-events: none;
display: flex;
flex-direction: column;
justify-content: flex-end;
}
.detail-backdrop {
position: absolute;
inset: 0;
background: rgba(10,11,15,0.7);
opacity: 0;
transition: opacity 0.3s;
backdrop-filter: blur(4px);
}
.detail-panel {
position: relative;
background: var(–surface);
border-radius: 20px 20px 0 0;
border-top: 1px solid var(–border);
max-height: 88dvh;
display: flex;
flex-direction: column;
transform: translateY(100%);
transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
padding-bottom: var(–safe-bottom);
}
.detail-sheet.open { pointer-events: all; }
.detail-sheet.open .detail-backdrop { opacity: 1; }
.detail-sheet.open .detail-panel { transform: translateY(0); }

.detail-handle {
width: 36px; height: 4px;
background: var(–border);
border-radius: 2px;
margin: 12px auto 0;
flex-shrink: 0;
}
.detail-header {
padding: 14px 20px 12px;
border-bottom: 1px solid var(–border);
display: flex;
align-items: flex-start;
gap: 12px;
flex-shrink: 0;
}
.detail-header-info { flex: 1; min-width: 0; }
.detail-title {
font-size: 0.9rem;
font-weight: 600;
line-height: 1.3;
margin-bottom: 4px;
}
.detail-meta {
font-family: ‘DM Mono’, monospace;
font-size: 0.6rem;
color: var(–muted);
letter-spacing: 0.08em;
text-transform: uppercase;
}
.detail-close {
background: var(–surface2);
border: none;
color: var(–muted);
font-size: 1rem;
width: 30px; height: 30px;
border-radius: 50%;
cursor: pointer;
flex-shrink: 0;
display: flex;
align-items: center;
justify-content: center;
}

.detail-body {
flex: 1;
overflow-y: auto;
-webkit-overflow-scrolling: touch;
padding: 16px 20px;
display: flex;
flex-direction: column;
gap: 14px;
}

.score-hero {
display: flex;
align-items: center;
gap: 14px;
background: var(–surface2);
border-radius: 12px;
padding: 14px 16px;
border: 1px solid var(–border);
}
.score-big {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 3.2rem;
line-height: 1;
flex-shrink: 0;
}
.score-big.good { color: var(–good); }
.score-big.mid { color: var(–mid); }
.score-big.bad { color: var(–bad); }
.score-hero-right { flex: 1; }
.score-verdict {
font-size: 0.8rem;
font-weight: 600;
margin-bottom: 6px;
line-height: 1.3;
}
.score-bar-wrap { display: flex; align-items: center; gap: 8px; }
.score-bar {
flex: 1;
height: 5px;
background: var(–surface3);
border-radius: 3px;
overflow: hidden;
}
.score-bar-fill {
height: 100%;
border-radius: 3px;
transition: width 0.6s ease;
}
.score-bar-fill.good { background: var(–good); }
.score-bar-fill.mid { background: var(–mid); }
.score-bar-fill.bad { background: var(–bad); }
.score-bar-pct {
font-family: ‘DM Mono’, monospace;
font-size: 0.6rem;
color: var(–muted);
flex-shrink: 0;
}

.section-title {
font-family: ‘DM Mono’, monospace;
font-size: 0.6rem;
letter-spacing: 0.12em;
text-transform: uppercase;
color: var(–muted);
margin-bottom: 8px;
}

.factor-list { display: flex; flex-direction: column; gap: 7px; }
.factor-row {
display: flex;
align-items: center;
gap: 9px;
font-size: 0.78rem;
}
.factor-icon { font-size: 0.9rem; flex-shrink: 0; }
.factor-label { flex: 1; color: var(–text); }
.factor-pts {
font-family: ‘DM Mono’, monospace;
font-size: 0.68rem;
font-weight: 500;
flex-shrink: 0;
}
.factor-pts.pos { color: var(–good); }
.factor-pts.neg { color: var(–bad); }

.kw-wrap { display: flex; flex-wrap: wrap; gap: 5px; }
.kw-tag {
background: rgba(200,240,32,0.1);
color: var(–accent);
font-family: ‘DM Mono’, monospace;
font-size: 0.6rem;
padding: 3px 9px;
border-radius: 6px;
border: 1px solid rgba(200,240,32,0.2);
}
.scam-tag {
background: rgba(240,40,80,0.1);
color: var(–bad);
font-family: ‘DM Mono’, monospace;
font-size: 0.6rem;
padding: 3px 9px;
border-radius: 6px;
border: 1px solid rgba(240,40,80,0.2);
}

.open-link-btn {
display: flex;
align-items: center;
justify-content: center;
gap: 8px;
width: 100%;
background: var(–surface2);
color: var(–teal);
border: 1px solid rgba(32,240,180,0.25);
border-radius: 12px;
padding: 13px;
font-family: ‘DM Mono’, monospace;
font-size: 0.72rem;
letter-spacing: 0.06em;
text-decoration: none;
cursor: pointer;
}

/* ── PAGE: DRAFTS ── */
.drafts-scroll {
flex: 1;
overflow-y: auto;
-webkit-overflow-scrolling: touch;
}

.draft-card {
margin: 12px 16px;
background: var(–surface);
border: 1px solid var(–border);
border-radius: 14px;
overflow: hidden;
transition: border-color 0.2s;
}
.draft-card.approved { border-color: rgba(32,240,180,0.3); }

.draft-card-header {
padding: 14px 16px;
display: flex;
align-items: flex-start;
gap: 10px;
cursor: pointer;
}
.draft-card-info { flex: 1; min-width: 0; }
.draft-card-title {
font-size: 0.82rem;
font-weight: 600;
margin-bottom: 3px;
white-space: nowrap;
overflow: hidden;
text-overflow: ellipsis;
}
.draft-card-subject {
font-size: 0.7rem;
color: var(–muted);
white-space: nowrap;
overflow: hidden;
text-overflow: ellipsis;
}
.draft-status-badge {
font-family: ‘DM Mono’, monospace;
font-size: 0.58rem;
padding: 3px 8px;
border-radius: 10px;
flex-shrink: 0;
margin-top: 2px;
}
.draft-status-badge.pending { background: rgba(240,184,32,0.15); color: var(–mid); }
.draft-status-badge.approved { background: rgba(32,240,180,0.15); color: var(–good); }

.draft-expand {
display: none;
flex-direction: column;
gap: 10px;
padding: 0 16px 14px;
}
.draft-card.open .draft-expand { display: flex; }

.draft-email-box {
background: var(–surface2);
border: 1px solid var(–border);
border-radius: 10px;
padding: 12px;
font-family: ‘DM Mono’, monospace;
font-size: 0.67rem;
line-height: 1.7;
color: #a0a4b8;
white-space: pre-wrap;
max-height: 200px;
overflow-y: auto;
-webkit-overflow-scrolling: touch;
}

.draft-btns { display: flex; gap: 8px; }
.btn-approve {
flex: 1;
background: rgba(32,240,180,0.12);
color: var(–good);
border: 1px solid rgba(32,240,180,0.35);
font-family: ‘DM Mono’, monospace;
font-size: 0.68rem;
letter-spacing: 0.04em;
padding: 11px 8px;
border-radius: 10px;
cursor: pointer;
-webkit-appearance: none;
}
.btn-approve:active { background: rgba(32,240,180,0.2); }
.btn-discard {
flex: 1;
background: transparent;
color: var(–muted);
border: 1px solid var(–border);
font-family: ‘DM Mono’, monospace;
font-size: 0.68rem;
letter-spacing: 0.04em;
padding: 11px 8px;
border-radius: 10px;
cursor: pointer;
-webkit-appearance: none;
}
.btn-discard:active { color: var(–bad); border-color: var(–bad); }
.btn-open-mail {
display: block;
width: 100%;
background: var(–accent);
color: #0a0b0f;
border: none;
font-family: ‘Bebas Neue’, sans-serif;
font-size: 1rem;
letter-spacing: 0.1em;
padding: 13px;
border-radius: 10px;
cursor: pointer;
text-align: center;
text-decoration: none;
-webkit-appearance: none;
}
.btn-open-mail:active { opacity: 0.82; }

/* ── MODAL (setup) ── */
.modal-overlay {
position: fixed;
inset: 0;
background: rgba(10,11,15,0.88);
display: flex;
align-items: flex-end;
z-index: 100;
backdrop-filter: blur(6px);
padding-bottom: var(–safe-bottom);
}
.modal-overlay.hidden { display: none; }
.modal {
background: var(–surface);
border-radius: 20px 20px 0 0;
border-top: 1px solid var(–border);
padding: 20px 20px 24px;
width: 100%;
max-height: 88dvh;
overflow-y: auto;
-webkit-overflow-scrolling: touch;
display: flex;
flex-direction: column;
gap: 14px;
}
.modal h2 {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 1.6rem;
letter-spacing: 0.08em;
color: var(–accent);
}
.modal p { font-size: 0.78rem; color: #808498; line-height: 1.65; }
.modal code {
display: block;
background: var(–surface2);
border: 1px solid var(–border);
border-radius: 10px;
padding: 14px;
font-family: ‘DM Mono’, monospace;
font-size: 0.62rem;
line-height: 1.7;
color: var(–teal);
white-space: pre;
overflow-x: auto;
-webkit-overflow-scrolling: touch;
}
.modal-steps { display: flex; flex-direction: column; gap: 10px; }
.modal-step {
display: flex;
align-items: flex-start;
gap: 10px;
font-size: 0.78rem;
color: #808498;
line-height: 1.5;
}
.step-num {
background: var(–surface3);
color: var(–accent);
font-family: ‘Bebas Neue’, sans-serif;
font-size: 0.9rem;
width: 24px; height: 24px;
border-radius: 50%;
display: flex;
align-items: center;
justify-content: center;
flex-shrink: 0;
margin-top: 1px;
}
.btn-modal-close {
width: 100%;
background: var(–accent);
color: #0a0b0f;
font-family: ‘Bebas Neue’, sans-serif;
font-size: 1.1rem;
letter-spacing: 0.1em;
border: none;
border-radius: 12px;
padding: 15px;
cursor: pointer;
-webkit-appearance: none;
margin-top: 4px;
}
</style>

</head>
<body>

<!-- Setup Modal -->

<div class="modal-overlay hidden" id="setupModal">
  <div class="modal">
    <div style="width:36px;height:4px;background:var(--border);border-radius:2px;margin:0 auto 4px;"></div>
    <h2>Setup Guide</h2>
    <p>Paste this script into your Google Sheet to let the scanner auto-pull all your Craigslist hyperlinks.</p>
    <code>function doGet() {
  var ss = SpreadsheetApp
    .getActiveSpreadsheet();
  var sheet = ss.getSheetByName("Sheet1");
  var range = sheet.getDataRange();
  var richValues = range.getRichTextValues();
  var links = [];
  for (var i=0;i<richValues.length;i++){
    for (var j=0;j<richValues[i].length;j++){
      var cell = richValues[i][j];
      var runs = cell.getRuns();
      for (var k=0;k<runs.length;k++){
        var url = runs[k].getLinkUrl();
        var text = runs[k].getText().trim();
        if (url && url.indexOf(
          "craigslist")>-1){
          links.push({url:url,label:text,
            city:sheet.getRange(1,j+1)
              .getValue()||"Unknown",
            category:sheet.getRange(3,j+1)
              .getValue()||"Unknown"
          });
        }
      }
    }
  }
  return ContentService
    .createTextOutput(
      JSON.stringify({links:links}))
    .setMimeType(
      ContentService.MimeType.JSON);
}</code>
