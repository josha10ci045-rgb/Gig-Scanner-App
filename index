<script>
// ── NAV ──
function goTo(tab) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('page-' + tab).classList.add('active');
  document.getElementById('nav-' + tab).classList.add('active');
}

function setFilter(f, el) {
  currentFilter = f;
  document.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
  renderListings();
}

// ── STATE ──
let listings = [];
let drafts = [];
let currentFilter = 'all';

// ── CRITERIA ──
const MATCH_KEYWORDS = [
  '3d','3d rendering','3d modeling','3d animation','3d visualization','3d artist','3d designer',
  'rendering','photorealistic','cgi','vfx','visual effects','motion graphics','animation',
  'blender','cinema 4d','c4d','maya','3ds max','houdini','zbrush','substance painter',
  'keyshot','octane','redshift','v-ray','unreal engine','unity','sketchfab',
  'architectural visualization','archviz','architectural rendering','interior rendering',
  'exterior rendering','product visualization','product rendering','product design',
  'cad','revit','sketchup','rhino','solidworks',
  'graphic design','graphic designer','logo design','logo','branding','brand identity',
  'visual identity','illustration','illustrator','photoshop','indesign','after effects',
  'adobe','vector','typography','layout design','print design','packaging design','infographic',
  'web design','web designer','ui design','ux design','ui/ux','user interface','user experience',
  'figma','wireframe','prototype','landing page','website design','front end design',
  'ai art','midjourney','stable diffusion','dalle','ai image',
  'data entry','data sorting','data cleaning','spreadsheet','excel','google sheets',
  'transcription','content writing','copywriting','social media content',
  'presentation design','powerpoint','pitch deck','slide deck',
  'game design','game art','game assets','ar','vr','augmented reality','virtual reality',
  'mixed reality','interactive','real-time','metaverse','nft art','digital art',
  'video editing','video production','motion design','explainer video','promotional video',
  'commercial','storyboard','concept art','character design','environment design'
];

const SCAM_FLAGS = [
  'work for exposure','exposure only','great for your portfolio','portfolio opportunity',
  'no pay','unpaid','volunteer','revenue share only','equity only','profit sharing only',
  "we can't pay","we have no budget",'spec work','free trial project',
  'pay to apply','registration fee','wire transfer','western union','gift card',
  'cashier\'s check','make $500/day','earn from home easily','multilevel','mlm','pyramid'
];

const DISQUALIFIERS = [
  'plumber','plumbing','electrician','hvac','roofing','landscaping','lawn care',
  'moving company','truck driver','cdl','warehouse','forklift','construction',
  'concrete','cleaning service','maid','janitorial','food service','delivery driver',
  'uber','lyft','rideshare','babysitter','childcare','nanny','dog walker','pet sitting','massage'
];

// ── SCAN ──
async function startScan() {
  const url = document.getElementById('sheetUrl').value.trim();
  if (!url) { alert('Please paste your Apps Script Web App URL first.'); return; }

  document.getElementById('scanBtn').disabled = true;
  setStatus('Fetching...', 'live');
  listings = []; drafts = [];
  renderListings(); renderDrafts();
  updateBadges();

  let links = [];
  try {
    const res = await fetch(url);
    const data = await res.json();
    links = data.links || [];
  } catch(e) {
    alert('Could not fetch from your Apps Script URL.\n\nMake sure it is deployed as a Web App with public access.');
    document.getElementById('scanBtn').disabled = false;
    setStatus('Error', '');
    return;
  }

  if (!links.length) {
    alert('No Craigslist URLs found. Check your Apps Script setup.');
    document.getElementById('scanBtn').disabled = false;
    setStatus('No links', '');
    return;
  }

  listings = links.map((l, i) => ({ ...l, index: i, status: 'pending', score: null, tier: null, factors: [], matchedKw: [], scamFlags: [], snippet: '', title: l.label || l.url }));
  document.getElementById('statTotal').textContent = listings.length;
  renderListings();
  updateBadges();
  goTo('listings');

  for (let i = 0; i < listings.length; i++) {
    const pct = Math.round((i / listings.length) * 100);
    document.getElementById('progressFill').style.width = pct + '%';
    document.getElementById('progressLabel').textContent = `${i+1} / ${listings.length}`;
    setStatus(`${i+1}/${listings.length}`, 'live');
    listings[i].status = 'scanning';
    renderListings();
    try { await scanOne(i); }
    catch(e) { listings[i].status = 'done'; listings[i].tier = 'bad'; listings[i].score = 0; listings[i].snippet = 'Could not fetch.'; }
    renderListings(); updateStats(); updateBadges();
  }

  document.getElementById('progressFill').style.width = '100%';
  document.getElementById('progressLabel').textContent = `${listings.length} / ${listings.length}`;
  const good = listings.filter(l => l.tier === 'good').length;
  setStatus(`Done · ${good} matches`, 'done');
  document.getElementById('scanBtn').disabled = false;
}

async function scanOne(i) {
  const l = listings[i];
  const res = await fetch('https://api.anthropic.com/v1/messages', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      model: 'claude-sonnet-4-20250514',
      max_tokens: 1000,
      system: `You are a gig relevance scorer for Joshua Atencio, freelance 3D designer at TruPixel Media.
Services: 3D Rendering, 3D Asset creation (polygon), Graphic Design, 3D Interactive (Unity/SketchFab/Shapeways), Concept Visualization.

Score 0-100 based on:
- Skill keyword match (3D, design, graphic, UI/UX, web, animation, video, AI tasks): up to 40pts
- Budget/pay clearly mentioned: +25pts | No budget at all: -20pts
- Professional/detailed listing: +15pts
- High-interest type (archviz, game, interactive, AR/VR): +10pts
- Scam indicators (exposure, no pay, wire transfer, MLM, pay to apply): score=0, tier=scam
- Unrelated industry (plumbing, driving, cleaning, construction): score=0, tier=bad

Tier: 70-100=good | 40-69=mid | 0-39=bad | scam=scam

For score>=70, write a personalized outreach email from Joshua referencing the specific gig type.

Respond ONLY with valid JSON, no markdown fences:
{"title":"...","snippet":"1 sentence what this gig is","score":0,"tier":"good|mid|bad|scam","factors":[{"icon":"emoji","label":"reason","pts":0,"cls":"pos|neg"}],"matchedKeywords":["..."],"scamFlags":[],"draftEmail":"full email or null","emailSubject":"subject or null"}`,
      messages: [{ role: 'user', content: `Score this listing:
URL: ${l.url}
Label: ${l.label}
City: ${l.city}
Category: ${l.category}` }]
    })
  });

  const data = await res.json();
  const raw = data.content.map(c => c.text || '').join('');
  let result;
  try { result = JSON.parse(raw.replace(/```json|```/g, '').trim()); }
  catch(e) { result = { title: l.label, snippet: l.category, score: 20, tier: 'bad', factors: [], matchedKeywords: [], scamFlags: [], draftEmail: null, emailSubject: null }; }

  listings[i].status = 'done';
  listings[i].title = result.title || l.label;
  listings[i].snippet = result.snippet || '';
  listings[i].score = result.score ?? 0;
  listings[i].tier = result.tier || 'bad';
  listings[i].factors = result.factors || [];
  listings[i].matchedKw = result.matchedKeywords || [];
  listings[i].scamFlags = result.scamFlags || [];

  if (result.draftEmail && result.tier === 'good') {
    drafts.push({
      id: Date.now() + i,
      listingIndex: i,
      title: listings[i].title,
      city: l.city,
      subject: result.emailSubject || '3D Design Services — TruPixel Media',
      body: result.draftEmail,
      status: 'pending',
      url: l.url,
      open: false
    });
    renderDrafts();
  }
}

// ── RENDER LISTINGS ──
function renderListings() {
  const container = document.getElementById('listingScroll');
  const filtered = listings.filter(l => {
    if (currentFilter === 'all') return true;
    return l.tier === currentFilter;
  });

  if (!filtered.length) {
    container.innerHTML = `<div class="empty-screen"><div class="empty-icon">🔍</div><div class="empty-text">${listings.length ? 'No listings match this filter.' : 'Run a scan first to see your listings here.'}</div></div>`;
    return;
  }

  container.innerHTML = filtered.map(l => {
    let badgeContent = '', badgeClass = 'pending';
    if (l.status === 'scanning') {
      badgeContent = '<div class="spinner"></div>';
      badgeClass = 'pending';
    } else if (l.tier === 'scam') { badgeContent = '🚩'; badgeClass = 'scam'; }
    else if (l.tier === 'good') { badgeContent = l.score; badgeClass = 'good'; }
    else if (l.tier === 'mid') { badgeContent = l.score; badgeClass = 'mid'; }
    else if (l.tier === 'bad') { badgeContent = l.score ?? '—'; badgeClass = 'bad'; }
    else { badgeContent = '—'; }

    return `<div class="listing-row" onclick="openDetail(${l.index})">
      <div class="score-badge ${badgeClass}">${badgeContent}</div>
      <div class="listing-row-info">
        <div class="listing-row-title">${l.title || l.label}</div>
        <div class="listing-row-meta">
          <span class="listing-row-city">${(l.city||'').substring(0,3).toUpperCase()}</span>
          <span class="listing-row-snippet">${l.snippet || l.category || ''}</span>
        </div>
      </div>
      <span class="chevron">›</span>
    </div>`;
  }).join('');
}

// ── DETAIL SHEET ──
function openDetail(index) {
  const l = listings[index];
  document.getElementById('detailTitle').textContent = l.title || l.label;
  document.getElementById('detailMeta').textContent = `${l.city || ''} · ${l.category || ''}`;

  const scoreClass = l.tier === 'good' ? 'good' : l.tier === 'mid' ? 'mid' : 'bad';
  const verdict = l.tier === 'good' ? '✅ Strong match — draft created'
    : l.tier === 'scam' ? '🚩 Flagged as likely scam'
    : l.tier === 'mid' ? '🟡 Possible match — review manually'
    : '❌ Not a good fit';

  const scorePct = Math.min(100, l.score || 0);

  document.getElementById('detailBody').innerHTML = `
    <div class="score-hero">
      <div class="score-big ${scoreClass}">${l.score ?? '—'}</div>
      <div class="score-hero-right">
        <div class="score-verdict" style="color:var(--${scoreClass === 'bad' ? 'bad' : scoreClass})">${verdict}</div>
        <div class="score-bar-wrap">
          <div class="score-bar"><div class="score-bar-fill ${scoreClass}" style="width:${scorePct}%"></div></div>
          <div class="score-bar-pct">${scorePct}/100</div>
        </div>
      </div>
    </div>

    ${l.factors?.length ? `
    <div>
      <div class="section-title">Score Breakdown</div>
      <div class="factor-list">
        ${l.factors.map(f => `<div class="factor-row">
          <span class="factor-icon">${f.icon}</span>
          <span class="factor-label">${f.label}</span>
          <span class="factor-pts ${f.cls}">${f.pts > 0 ? '+' : ''}${f.pts}</span>
        </div>`).join('')}
      </div>
    </div>` : ''}

    ${l.matchedKw?.length ? `
    <div>
      <div class="section-title">Matched Keywords</div>
      <div class="kw-wrap">${l.matchedKw.map(k => `<span class="kw-tag">${k}</span>`).join('')}</div>
    </div>` : ''}

    ${l.scamFlags?.length ? `
    <div>
      <div class="section-title" style="color:var(--bad)">Scam Flags</div>
      <div class="kw-wrap">${l.scamFlags.map(k => `<span class="scam-tag">${k}</span>`).join('')}</div>
    </div>` : ''}

    ${l.snippet ? `<div style="font-size:0.8rem;line-height:1.65;color:#8890a8;">${l.snippet}</div>` : ''}

    <a class="open-link-btn" href="${l.url}" target="_blank">↗ Open on Craigslist</a>
  `;

  document.getElementById('detailSheet').classList.add('open');
}

function closeDetail() {
  document.getElementById('detailSheet').classList.remove('open');
}

// ── RENDER DRAFTS ──
function renderDrafts() {
  const container = document.getElementById('draftsScroll');
  if (!drafts.length) {
    container.innerHTML = `<div class="empty-screen"><div class="empty-icon">✉️</div><div class="empty-text">Strong matches will generate outreach drafts here for your review and approval.</div></div>`;
    return;
  }

  container.innerHTML = drafts.map((d, i) => `
    <div class="draft-card ${d.status} ${d.open ? 'open' : ''}" id="dc-${d.id}">
      <div class="draft-card-header" onclick="toggleDraft(${i})">
        <div class="draft-card-info">
          <div class="draft-card-title">${d.title}</div>
          <div class="draft-card-subject">${d.subject}</div>
        </div>
        <span class="draft-status-badge ${d.status}">${d.status === 'approved' ? '✓ Approved' : 'Pending'}</span>
      </div>
      <div class="draft-expand">
        <div class="draft-email-box">${d.body}</div>
        <div class="draft-btns">
          ${d.status !== 'approved'
            ? `<button class="btn-approve" onclick="approveDraft(${i})">✓ Approve</button>
               <button class="btn-discard" onclick="discardDraft(${i})">Discard</button>`
            : `<a class="btn-open-mail" href="mailto:?subject=${encodeURIComponent(d.subject)}&body=${encodeURIComponent(d.body)}">Open in Mail ↗</a>`
          }
        </div>
      </div>
    </div>`).join('');
}

function toggleDraft(i) { drafts[i].open = !drafts[i].open; renderDrafts(); }
function approveDraft(i) { drafts[i].status = 'approved'; drafts[i].open = true; renderDrafts(); }
function discardDraft(i) { if (confirm('Discard this draft?')) { drafts.splice(i,1); renderDrafts(); updateBadges(); } }

// ── HELPERS ──
function updateStats() {
  document.getElementById('statGood').textContent = listings.filter(l=>l.tier==='good').length;
  document.getElementById('statMid').textContent = listings.filter(l=>l.tier==='mid').length;
  document.getElementById('statBad').textContent = listings.filter(l=>l.tier==='bad'||l.tier==='scam').length;
}

function updateBadges() {
  const lb = document.getElementById('listingsBadge');
  const db = document.getElementById('draftsBadge');
  if (listings.length) { lb.style.display = 'flex'; lb.textContent = listings.length; }
  else { lb.style.display = 'none'; }
  if (drafts.length) { db.style.display = 'flex'; db.textContent = drafts.length; }
  else { db.style.display = 'none'; }
}

function setStatus(text, cls) {
  const pill = document.getElementById('statusPill');
  pill.textContent = text;
  pill.className = 'status-pill' + (cls ? ' ' + cls : '');
}
</script>

